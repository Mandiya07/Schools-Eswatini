# === REQUIRED CORE CONFIG ===
GEMINI_API_KEY=
NODE_ENV=development

# === OPTIONAL: EXTERNAL NOTIFICATIONS ===
# Add these to enable real email/SMS. If missing, app will log to console (MOCK MODE).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=no-reply@schoolseswatini.sz

# Twilio (International SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Local SMS Aggregator (Eswatini specific)
LOCAL_SMS_API_URL=
LOCAL_SMS_API_KEY=

# === OPTIONAL: PAYMENTS ===
# Default sandbox keys are provided in server.ts if these are missing.
MOMO_API_USER=
MOMO_API_KEY=
MOMO_SUB_KEY=
MOMO_ENVIRONMENT=sandbox

# === OTHER ===
VITE_APP_URL=
VITE_API_BASE_URL=
