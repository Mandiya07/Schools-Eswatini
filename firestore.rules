rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    match /_connection_test_/ping {
      allow read: if true;
    }

    // ===============================================================
    // PRIMITIVE HELPERS
    // ===============================================================
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { 
      return request.auth != null; 
    }
    
    // Auth tokens never contain custom claims in this architecture. 
    function isAdmin() { 
      return (request.auth != null && request.auth.token.email != null && request.auth.token.email == "siphom.yati@gmail.com") || 
             (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Super Admin');
    }
    
    function isInstitutionAdmin(institutionId) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.institutionId == institutionId &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Institution Admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    // ===============================================================
    // VALIDATION HELPERS (Anti-Update-Gap Blueprints)
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'email', 'name', 'role']) &&
             data.id is string && data.id.size() > 0 && data.id.size() <= 128 &&
             data.email is string && data.email.size() <= 200 &&
             data.name is string && data.name.size() <= 150 &&
             data.role in ['Super Admin', 'Institution Admin', 'Visitor', 'MoET Official', 'Parent', 'Teacher'];
    }

    function isValidInstitution(data) {
      return data.keys().hasAll(['id', 'name', 'slug', 'region', 'status']) &&
             data.id is string && data.id.size() > 0 && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 150 &&
             data.slug is string && data.slug.size() <= 150 &&
             data.region in ['Hhohho', 'Manzini', 'Lubombo', 'Shiselweni'] &&
             data.status in ['pending', 'published', 'suspended'];
    }

    function isValidReview(data) {
      return data.keys().hasAll(['id', 'institutionId', 'userId', 'userName', 'rating', 'comment', 'status', 'createdAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.institutionId is string && data.institutionId.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.userName is string && data.userName.size() <= 150 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 2000 &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.createdAt is string; // using toISOString() in the app instead of Server Value unfortunately
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['id', 'institutionId', 'senderId', 'senderName', 'senderEmail', 'subject', 'body', 'status', 'createdAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.institutionId is string && data.institutionId.size() <= 128 &&
             data.senderId is string && data.senderId.size() <= 128 &&
             data.senderName is string && data.senderName.size() <= 150 &&
             data.senderEmail is string && data.senderEmail.size() <= 200 &&
             data.subject is string && data.subject.size() <= 200 &&
             data.body is string && data.body.size() <= 5000 &&
             data.status in ['unread', 'read', 'archived'] &&
             data.createdAt is string;
    }

    function isValidStudent(data) {
      return data.keys().hasAll(['id', 'institutionId', 'name', 'grade', 'class', 'studentId', 'dob', 'parentEmails', 'createdAt']) &&
             data.id is string && data.id.size() > 0 && data.id.size() <= 128 &&
             data.institutionId is string && data.institutionId.size() <= 128 &&
             data.name is string && data.name.size() <= 150 &&
             data.grade is string && data.grade.size() <= 50 &&
             data.class is string && data.class.size() <= 50 &&
             data.studentId is string && data.studentId.size() <= 50 &&
             data.dob is string && data.dob.size() <= 20 &&
             data.parentEmails is list && (data.parentEmails.size() == 0 || (data.parentEmails.size() <= 10 && data.parentEmails[0] is string)) &&
             data.createdAt is string;
    }

    function isValidStudentProgress(data) {
      return data.keys().hasAll(['id', 'studentId', 'studentName', 'institutionId', 'term', 'year', 'academics', 'behavior', 'participation', 'lastUpdated']) &&
             data.id is string && data.id.size() <= 128 &&
             data.studentId is string && data.studentId.size() <= 128 &&
             data.studentName is string && data.studentName.size() <= 150 &&
             data.institutionId is string && data.institutionId.size() <= 128 &&
             data.term is string && data.term.size() <= 50 &&
             data.year is number &&
             data.academics is list && (data.academics.size() == 0 || data.academics[0] is map) &&
             data.behavior is map &&
             data.participation is map &&
             data.lastUpdated is string;
    }

    function isValidResource(data) {
      return data.keys().hasAll(['id', 'title', 'subject', 'level', 'price', 'sellerId', 'createdAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.subject is string && data.subject.size() <= 100 &&
             data.level is string && data.level.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.sellerId is string && data.sellerId.size() <= 128 &&
             data.createdAt is string;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['id', 'resourceId', 'buyerId', 'sellerId', 'amount', 'status', 'createdAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.resourceId is string && data.resourceId.size() <= 128 &&
             data.buyerId is string && data.buyerId.size() <= 128 &&
             data.sellerId is string && data.sellerId.size() <= 128 &&
             data.amount is number && data.amount >= 0 &&
             data.status in ['pending', 'completed', 'failed'] &&
             data.createdAt is string;
    }

    function isValidSchoolClaim(data) {
      return data.keys().hasAll(['id', 'institutionId', 'institutionName', 'userId', 'userEmail', 'status', 'createdAt']) &&
             data.id is string && data.id.size() <= 128 &&
             data.institutionId is string && data.institutionId.size() <= 128 &&
             data.institutionName is string && data.institutionName.size() <= 150 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.userEmail is string && data.userEmail.size() <= 200 &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.createdAt is string;
    }

    // ===============================================================
    // RULES
    // ===============================================================

    match /users/{userId} {
      // PII Isolation: Only owner or admin can read the user
      allow get: if isValidId(userId) && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      
      // Strict keys + Auth verification + Default Role Forcement
      allow create: if isValidId(userId) && 
                       isOwner(userId) && 
                       incoming().id == userId &&
                       isValidUser(incoming()) && 
                       // Regular signup can only make them Visitor or Parent
                       // Only an existing Admin can create an Institution Admin or Super Admin
                       (incoming().role in ['Visitor', 'Parent', 'Teacher'] || isAdmin());

      allow update: if isValidId(userId) && 
                       (isOwner(userId) || isAdmin()) && 
                       isValidUser(incoming()) && 
                       // No self-escalation
                       (incoming().role == existing().role || isAdmin()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['name', 'role', 'institutionId', 'isVerified']);
    }

    match /institutions/{institutionId} {
      allow get: if isValidId(institutionId) && (
        isAdmin() ||
        resource.data.status == 'published' || 
        (isSignedIn() && (
          resource.data.adminId == request.auth.uid ||
          request.auth.token.email == "siphom.yati@gmail.com" ||
          (resource.data.get('teacherEmails', []) != null && request.auth.token.email in resource.data.get('teacherEmails', []))
        ))
      );
      
      allow list: if 
        isAdmin() ||
        resource.data.status == 'published' || 
        (isSignedIn() && (
          resource.data.adminId == request.auth.uid ||
          request.auth.token.email == "siphom.yati@gmail.com"
        ));
      
      // Only admins can create directly, or if a user creates it must be 'pending' status
      allow create: if isValidId(institutionId) && 
                       isSignedIn() &&
                       isValidInstitution(incoming()) && 
                       incoming().id == institutionId &&
                       (isAdmin() || incoming().status == 'pending');

      allow update: if isValidId(institutionId) && 
                       isSignedIn() &&
                       isValidInstitution(incoming()) &&
                       (isAdmin() || 
                        (isInstitutionAdmin(institutionId) && existing().status == 'published' && incoming().status == 'published'));
                        
      allow delete: if isValidId(institutionId) && isAdmin();
    }

    match /reviews/{reviewId} {
      // List: Ensure users filter safely, but reviews can also be publicly read if approved.
      allow get: if isValidId(reviewId) && 
                      (resource.data.status == 'approved' || 
                       (isSignedIn() && (resource.data.userId == request.auth.uid || isInstitutionAdmin(resource.data.institutionId) || isAdmin())));
      
      allow list: if resource.data.status == 'approved' || 
                      (isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()));
                      
      allow create: if isValidId(reviewId) && 
                       isSignedIn() && 
                       isValidReview(incoming()) && 
                       incoming().userId == request.auth.uid &&
                       incoming().status == 'pending' &&
                       exists(/databases/$(database)/documents/institutions/$(incoming().institutionId));
                       
      // Admins can approve/reject
      allow update: if isValidId(reviewId) && 
                       isSignedIn() && 
                       isValidReview(incoming()) &&
                       (isAdmin() || isInstitutionAdmin(existing().institutionId)) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['status']);
                       
      allow delete: if isValidId(reviewId) && (isAdmin() || (isSignedIn() && existing().userId == request.auth.uid));
    }

    match /messages/{messageId} {
      // Data Bleed Prevention: Can only read if you are the sender or the institution admin
      allow get: if isValidId(messageId) && 
                     isSignedIn() && 
                     (resource.data.senderId == request.auth.uid || isInstitutionAdmin(resource.data.institutionId) || isAdmin());
      
      allow list: if isSignedIn() && (resource.data.senderId == request.auth.uid || isAdmin());
                     
      allow create: if isValidId(messageId) && 
                       isSignedIn() && 
                       isValidMessage(incoming()) && 
                       incoming().senderId == request.auth.uid &&
                       exists(/databases/$(database)/documents/institutions/$(incoming().institutionId));
                       
      // E.g., for marking as read or admin replies. The sender cannot update it.
      allow update: if isValidId(messageId) && 
                       isSignedIn() && 
                       isValidMessage(incoming()) && 
                       (isAdmin() || isInstitutionAdmin(existing().institutionId)) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['status', 'adminReply']);
                       
      allow delete: if isValidId(messageId) && isAdmin();
    }

     match /student_progress/{progressId} {
      allow get: if isValidId(progressId) && 
                     isSignedIn() && 
                     (isInstitutionAdmin(resource.data.institutionId) || 
                      isAdmin() || 
                      (get(/databases/$(database)/documents/students/$(resource.data.studentId)).data.parentEmails.hasAny([request.auth.token.email])));
      
      allow list: if isSignedIn() && (resource.data.institutionId != null || isAdmin()); // More complex checks needed for parents
                       
      allow create: if isValidId(progressId) && 
                       isSignedIn() && 
                       isValidStudentProgress(incoming()) && 
                       (isInstitutionAdmin(incoming().institutionId) || isAdmin());
                       
      allow update: if isValidId(progressId) && 
                       isSignedIn() && 
                       isValidStudentProgress(incoming()) && 
                       (isInstitutionAdmin(existing().institutionId) || isAdmin()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['academics', 'behavior', 'participation', 'lastUpdated', 'term', 'year']);
                       
      allow delete: if isValidId(progressId) && (isInstitutionAdmin(existing().institutionId) || isAdmin());
    }

    match /students/{studentDocId} {
      allow get: if isValidId(studentDocId) && 
                     isSignedIn() && 
                     (isInstitutionAdmin(resource.data.institutionId) || isAdmin() || (request.auth.token.email in resource.data.parentEmails));
      
      allow list: if isSignedIn() && (resource.data.institutionId != null || isAdmin());
                     
      allow create: if isValidId(studentDocId) && 
                       isSignedIn() && 
                       isValidStudent(incoming()) && 
                       incoming().id == studentDocId &&
                       (isInstitutionAdmin(incoming().institutionId) || isAdmin());
                       
      allow update: if isValidId(studentDocId) && 
                       isSignedIn() && 
                       isValidStudent(incoming()) && 
                       (isInstitutionAdmin(existing().institutionId) || isAdmin()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['name', 'grade', 'class', 'studentId', 'dob', 'parentEmails']);
                       
      allow delete: if isValidId(studentDocId) && (isInstitutionAdmin(existing().institutionId) || isAdmin());
    }

    match /resources/{resourceId} {
      allow get: if isValidId(resourceId);
      allow list: if true;
      
      allow create: if isValidId(resourceId) && 
                       isSignedIn() && 
                       isValidResource(incoming()) && 
                       incoming().id == resourceId &&
                       (incoming().sellerId == request.auth.uid || isAdmin());
      allow update: if isValidId(resourceId) && 
                       isSignedIn() && 
                       isValidResource(incoming()) && 
                       (existing().sellerId == request.auth.uid || isAdmin()) &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'price', 'tags', 'fileUrl', 'thumbnail']);
      allow delete: if isValidId(resourceId) && (existing().sellerId == request.auth.uid || isAdmin());
    }

    match /transactions/{transactionId} {
      allow get: if isValidId(transactionId) && 
                     isSignedIn() && 
                     (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid || isAdmin());
      
      allow list: if isSignedIn() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid || isAdmin());
      
      allow create: if isValidId(transactionId) && 
                       isSignedIn() && 
                       isValidTransaction(incoming()) && 
                       incoming().id == transactionId &&
                       incoming().buyerId == request.auth.uid &&
                       incoming().status == 'pending';
      allow update: if isValidId(transactionId) && isAdmin(); // Only system can update status
      allow delete: if false;
    }

    match /alumni_profiles/{profileId} {
      // Publicly viewable if marked isPublic, or if it belongs to the user, or admins
      allow get: if isValidId(profileId) && 
                     (resource.data.isPublic == true ||
                      (isSignedIn() && (resource.data.userId == request.auth.uid || isInstitutionAdmin(resource.data.institutionId) || isAdmin())));
      
      allow list: if resource.data.isPublic == true || 
                      (isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()));
      
      allow create: if isValidId(profileId) && isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isValidId(profileId) && isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow delete: if isValidId(profileId) && isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    match /success_stories/{storyId} {
      allow get: if isValidId(storyId);
      allow list: if true;
      allow create, update, delete: if isValidId(storyId) && isSignedIn() && 
                                       (isInstitutionAdmin(incoming().institutionId) || isAdmin());
    }

    match /fundraising_campaigns/{campaignId} {
      allow get: if isValidId(campaignId);
      allow list: if true;
      allow create, update, delete: if isValidId(campaignId) && isSignedIn() && 
                                       (isInstitutionAdmin(incoming().institutionId) || isAdmin());
    }

    match /school_applications/{appId} {
      allow get: if isValidId(appId) && isSignedIn() && (resource.data.email == request.auth.token.email || isAdmin());
      allow list: if isSignedIn() && (resource.data.email == request.auth.token.email || isAdmin());
      allow create: if isValidId(appId) && isSignedIn();
      allow update, delete: if isValidId(appId) && isAdmin();
    }

    match /school_claims/{claimId} {
      allow get: if isValidId(claimId) && isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isValidId(claimId) && isSignedIn() && 
                       isValidSchoolClaim(incoming()) && 
                       incoming().id == claimId &&
                       incoming().userId == request.auth.uid && 
                       incoming().status == 'pending';
      allow update: if isValidId(claimId) && isSignedIn() && (
                       isAdmin() || 
                       (existing().userId == request.auth.uid && 
                        incoming().userId == request.auth.uid && 
                        isValidSchoolClaim(incoming()) &&
                        incoming().diff(existing()).affectedKeys().hasOnly(['justification', 'phone']))
                    );
      allow delete: if isValidId(claimId) && isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    match /audit_logs/{logId} {
      allow get: if isValidId(logId) && isAdmin();
      allow list: if isAdmin();
      allow create: if isValidId(logId) && isSignedIn();
      allow update, delete: if false; // Immutable
    }

    match /activity_history/{historyId} {
      allow get: if isValidId(historyId) && isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isValidId(historyId) && isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if false; // Immutable
    }
  }
}
