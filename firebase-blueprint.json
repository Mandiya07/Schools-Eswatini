{
  "entities": {
    "User": {
      "title": "User",
      "description": "Application user profile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["Super Admin", "Institution Admin", "Visitor"] },
        "institutionId": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "twoFactorEnabled": { "type": "boolean" }
      },
      "required": ["id", "email", "name", "role"]
    },
    "Institution": {
      "title": "Institution",
      "description": "Educational institution details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "logo": { "type": "string" },
        "coverImage": { "type": "string" },
        "region": { "type": "string", "enum": ["Hhohho", "Manzini", "Lubombo", "Shiselweni"] },
        "type": { "type": "array", "items": { "type": "string" } },
        "isVerified": { "type": "boolean" },
        "isAccredited": { "type": "boolean" },
        "moetRegistration": { "type": "string" },
        "isFeatured": { "type": "boolean" },
        "trustScore": { "type": "number" },
        "plan": { "type": "string", "enum": ["Free", "Premium", "Enterprise"] },
        "status": { "type": "string", "enum": ["pending", "published", "suspended"] },
        "adminId": { "type": "string" },
        "metadata": { "type": "object" },
        "contact": { "type": "object" },
        "sections": { "type": "object" },
        "stats": { "type": "object" }
      },
      "required": ["id", "name", "slug", "region", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "Institution review or testimonial",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "institutionId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userRole": { "type": "string", "enum": ["parent", "alumni", "visitor"] },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "institutionId", "userId", "userName", "rating", "comment", "status", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Direct inquiry or internal message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "institutionId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderEmail": { "type": "string", "format": "email" },
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "status": { "type": "string", "enum": ["unread", "read", "archived"] },
        "isDirectInquiry": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "institutionId", "senderName", "senderEmail", "subject", "body", "status", "createdAt"]
    },
    "AlumniProfile": {
      "title": "Alumni Profile",
      "description": "Alumni registration details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "institutionId": { "type": "string" },
        "graduationYear": { "type": "number" },
        "major": { "type": "string" },
        "currentJob": { "type": "string" },
        "bio": { "type": "string" },
        "isPublic": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "institutionId", "graduationYear", "createdAt"]
    },
    "SuccessStory": {
      "title": "Success Story",
      "description": "Alumni success story",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "institutionId": { "type": "string" },
        "alumniId": { "type": "string" },
        "alumniName": { "type": "string" },
        "title": { "type": "string" },
        "story": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "institutionId", "alumniName", "title", "story", "createdAt"]
    },
    "FundraisingCampaign": {
      "title": "Fundraising Campaign",
      "description": "Institution fundraising campaign",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "institutionId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "goalAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "deadline": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "institutionId", "title", "description", "goalAmount", "currentAmount", "createdAt"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "System-wide audit log for security events",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "resource": { "type": "string" },
        "resourceId": { "type": "string" },
        "details": { "type": "object" },
        "ipAddress": { "type": "string" },
        "userAgent": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "action", "resource", "createdAt"]
    },
    "ActivityHistory": {
      "title": "Activity History",
      "description": "User-specific activity history",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["login", "logout", "profile_update", "review_submit", "inquiry_send"] },
        "description": { "type": "string" },
        "metadata": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "type", "description", "createdAt"]
    },
    "Student": {
      "title": "Student",
      "description": "Student record managed by institution",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "institutionId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "grade": { "type": "string" },
        "class": { "type": "string" },
        "studentId": { "type": "string" },
        "dob": { "type": "string", "format": "date" },
        "parentEmails": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "institutionId", "name", "studentId", "parentEmails"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/institutions/{institutionId}": {
      "schema": "Institution",
      "description": "Institution details"
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Student records"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Institution reviews"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Inquiries and messages"
    },
    "/alumni_profiles/{profileId}": {
      "schema": "AlumniProfile",
      "description": "Alumni profiles"
    },
    "/success_stories/{storyId}": {
      "schema": "SuccessStory",
      "description": "Alumni success stories"
    },
    "/fundraising_campaigns/{campaignId}": {
      "schema": "FundraisingCampaign",
      "description": "Fundraising campaigns"
    },
    "/audit_logs/{logId}": {
      "schema": "AuditLog",
      "description": "System audit logs"
    },
    "/activity_history/{historyId}": {
      "schema": "ActivityHistory",
      "description": "User activity history"
    }
  }
}
