{
  "entities": {
    "User": {
      "title": "User",
      "description": "Application user profile",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["Super Admin", "Institution Admin", "Visitor"] },
        "institutionId": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "twoFactorEnabled": { "type": "boolean" }
      },
      "required": ["id", "email", "name", "role"]
    },
    "Institution": {
      "title": "Institution",
      "description": "Educational institution details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "logo": { "type": "string" },
        "coverImage": { "type": "string" },
        "region": { "type": "string", "enum": ["Hhohho", "Manzini", "Lubombo", "Shiselweni"] },
        "type": { "type": "array", "items": { "type": "string" } },
        "isVerified": { "type": "boolean" },
        "isAccredited": { "type": "boolean" },
        "moetRegistration": { "type": "string" },
        "isFeatured": { "type": "boolean" },
        "trustScore": { "type": "number" },
        "plan": { "type": "string", "enum": ["Free", "Premium", "Enterprise"] },
        "status": { "type": "string", "enum": ["pending", "published", "suspended"] },
        "adminId": { "type": "string" },
        "metadata": { "type": "object" },
        "contact": { "type": "object" },
        "sections": { "type": "object" },
        "stats": { "type": "object" }
      },
      "required": ["id", "name", "slug", "region", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "Institution review or testimonial",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "institutionId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userRole": { "type": "string", "enum": ["parent", "alumni", "visitor"] },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "institutionId", "userId", "userName", "rating", "comment", "status", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Direct inquiry or internal message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "institutionId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderEmail": { "type": "string", "format": "email" },
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "status": { "type": "string", "enum": ["unread", "read", "archived"] },
        "isDirectInquiry": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "institutionId", "senderName", "senderEmail", "subject", "body", "status", "createdAt"]
    },
    "AlumniProfile": {
      "title": "Alumni Profile",
      "description": "Alumni registration details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "institutionId": { "type": "string" },
        "graduationYear": { "type": "number" },
        "major": { "type": "string" },
        "currentJob": { "type": "string" },
        "bio": { "type": "string" },
        "isPublic": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "institutionId", "graduationYear", "createdAt"]
    },
    "SuccessStory": {
      "title": "Success Story",
      "description": "Alumni success story",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "institutionId": { "type": "string" },
        "alumniId": { "type": "string" },
        "alumniName": { "type": "string" },
        "title": { "type": "string" },
        "story": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "institutionId", "alumniName", "title", "story", "createdAt"]
    },
    "FundraisingCampaign": {
      "title": "Fundraising Campaign",
      "description": "Institution fundraising campaign",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "institutionId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "goalAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "deadline": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "institutionId", "title", "description", "goalAmount", "currentAmount", "createdAt"]
    },
    "SchoolApplication": {
      "title": "School Application",
      "description": "Pending school registration application",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "institutionName": { "type": "string" },
        "email": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "approved", "rejected"] },
        "documentUrls": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "institutionName", "email", "status", "createdAt"]
    },
    "SchoolClaim": {
      "title": "School Claim",
      "description": "User claim application to become school admin",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "institutionId": { "type": "string" },
        "institutionName": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string", "format": "email" },
        "userName": { "type": "string" },
        "justification": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "documentUrl": { "type": "string" },
        "decisionReason": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "institutionId", "institutionName", "userId", "userEmail", "status", "createdAt"]
    },
    "AuditLog": {
      "title": "Audit Log",
      "description": "System-wide audit log for security events",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "resource": { "type": "string" },
        "resourceId": { "type": "string" },
        "details": { "type": "object" },
        "ipAddress": { "type": "string" },
        "userAgent": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "action", "resource", "createdAt"]
    },
    "ActivityHistory": {
      "title": "Activity History",
      "description": "User-specific activity history",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["login", "logout", "profile_update", "review_submit", "inquiry_send"] },
        "description": { "type": "string" },
        "metadata": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "type", "description", "createdAt"]
    },
    "Student": {
      "title": "Student",
      "description": "Student record managed by institution",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "institutionId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "grade": { "type": "string" },
        "class": { "type": "string" },
        "studentId": { "type": "string" },
        "dob": { "type": "string", "format": "date" },
        "parentEmails": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "institutionId", "name", "studentId", "parentEmails"]
    },
    "StudentProgress": {
      "title": "Student Progress",
      "description": "Academic progress records for students",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "institutionId": { "type": "string" },
        "term": { "type": "string" },
        "year": { "type": "number" },
        "academics": { "type": "array", "items": { "type": "object" } },
        "behavior": { "type": "object" },
        "participation": { "type": "object" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "studentId", "institutionId", "term", "year"]
    },
    "Resource": {
      "title": "Resource",
      "description": "Study material available in the marketplace",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "subject": { "type": "string" },
        "level": { "type": "string" },
        "price": { "type": "number" },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "fileUrl": { "type": "string" },
        "thumbnail": { "type": "string" },
        "type": { "type": "string", "enum": ["Notes", "Past Paper", "Guide"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "stats": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "subject", "level", "price", "sellerId", "createdAt"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Marketplace purchase record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "resourceId": { "type": "string" },
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "paymentMethod": { "type": "string" },
        "momoReference": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "resourceId", "buyerId", "sellerId", "amount", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/institutions/{institutionId}": {
      "schema": "Institution",
      "description": "Institution details"
    },
    "/students/{studentId}": {
      "schema": "Student",
      "description": "Student records"
    },
    "/student_progress/{progressId}": {
      "schema": "StudentProgress",
      "description": "Academic progress reports"
    },
    "/resources/{resourceId}": {
      "schema": "Resource",
      "description": "Marketplace resources"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Payment transactions"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Institution reviews"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Inquiries and messages"
    },
    "/alumni_profiles/{profileId}": {
      "schema": "AlumniProfile",
      "description": "Alumni profiles"
    },
    "/success_stories/{storyId}": {
      "schema": "SuccessStory",
      "description": "Alumni success stories"
    },
    "/fundraising_campaigns/{campaignId}": {
      "schema": "FundraisingCampaign",
      "description": "Fundraising campaigns"
    },
    "/audit_logs/{logId}": {
      "schema": "AuditLog",
      "description": "System audit logs"
    },
    "/activity_history/{historyId}": {
      "schema": "ActivityHistory",
      "description": "User activity history"
    },
    "/school_applications/{applicationId}": {
      "schema": "SchoolApplication",
      "description": "Pending school registration applications"
    },
    "/school_claims/{claimId}": {
      "schema": "SchoolClaim",
      "description": "School claim applications"
    }
  }
}
